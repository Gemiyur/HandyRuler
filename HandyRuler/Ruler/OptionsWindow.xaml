<Window x:Class="Ruler.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ruler"
        mc:Ignorable="d"
        Title="Настройки линейки" 
        Icon="/ruler;component/images/ruler.ico"
        FontSize="{Binding DialogFontSize}"
        Width="525"
        SizeToContent="Height"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <local:EnumBooleanConverter x:Key="enumBool" />
        <local:InverseBooleanConverter x:Key="not" />

        <Style x:Key="FontInputControlStyle" TargetType="Control">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,5,0,0" />
        </Style>

        <Style x:Key="FontTextBlockBaseStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Стиль блоков предпросмотра шрифта. -->
        <!-- Закомментирован, как и сами блоки, т.к. не имеют смысла, ибо настройки применятся сразу. -->
        <!--<Style x:Key="FontTextBlockSampleStyle" BasedOn="{StaticResource FontTextBlockBaseStyle}" TargetType="TextBlock">
            <Setter Property="Margin" Value="20,5,0,0" />
        </Style>-->

        <Style x:Key="FontTextBlockStyle" BasedOn="{StaticResource FontTextBlockBaseStyle}" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>

        <Style x:Key="FontTextBoxStyle" BasedOn="{StaticResource FontInputControlStyle}" TargetType="TextBox">
            <Setter Property="Width" Value="48" />
        </Style>

        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>
 
        <Style x:Key="HorizontalToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="15,0,0,0" />
        </Style>

        <Style x:Key="VerticalToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="3,5,3,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <GroupBox Grid.Column="0" Header="Ориентация">
                <StackPanel>
                    <RadioButton GroupName="Style" Content="Горизонтальная" Style="{StaticResource VerticalToggleButtonStyle}"
                                 IsChecked="{Binding Orientation, 
                                    Converter={StaticResource enumBool}, ConverterParameter=Horizontal}" />
                    <RadioButton GroupName="Style" Content="Вертикальная" Style="{StaticResource VerticalToggleButtonStyle}"
                                 IsChecked="{Binding Orientation, 
                                    Converter={StaticResource enumBool}, ConverterParameter=Vertical}" />
                </StackPanel>
            </GroupBox>
            <GroupBox Grid.Column="1" Header="Нулевая точка" Margin="20,0,0,0">
                <StackPanel>
                    <RadioButton GroupName="Zero" Content="Слева (сверху)" Style="{StaticResource VerticalToggleButtonStyle}"
                                 IsChecked="{Binding ZeroPoint, 
                                    Converter={StaticResource enumBool}, ConverterParameter=Near}" />
                    <RadioButton GroupName="Zero" Content="Справа (снизу)" Style="{StaticResource VerticalToggleButtonStyle}"
                                 IsChecked="{Binding ZeroPoint, 
                                    Converter={StaticResource enumBool}, ConverterParameter=Far}" />
                </StackPanel>
            </GroupBox>
            <GroupBox Grid.Column="2" Header="Шкала" Margin="20,0,0,0">
                <StackPanel>
                    <CheckBox Content="Снизу (слева)" Style="{StaticResource VerticalToggleButtonStyle}"
                              IsChecked="{Binding Flip}" />
                    <CheckBox Content="Узкая" Style="{StaticResource VerticalToggleButtonStyle}"
                              IsChecked="{Binding ThinScale}" />
                </StackPanel>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="1" Header="Окно" Style="{StaticResource GroupBoxStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <CheckBox Content="Рамка линейки" Margin="3,5,0,0"
                              IsChecked="{Binding ShowBorders}" />
                    <CheckBox Content="Поверх всех окон" Margin="20,5,0,0"
                              IsChecked="{Binding TopMost}" />
                </StackPanel>
                <DockPanel LastChildFill="True" Margin="0,5,0,0">
                    <Label Content="Непрозрачность" Margin="0,0,0,5" />
                    <Slider VerticalAlignment="Center" 
                            Value="{Binding Opacity}"
                            Minimum="0.1"
                            Maximum="1.0"
                            TickFrequency=".1"
                            LargeChange=".1"
                            IsSnapToTickEnabled="True" 
                            AutoToolTipPlacement="TopLeft"
                            AutoToolTipPrecision="1"
                            Margin="0,0,5,0" />
                </DockPanel>
            </StackPanel>
        </GroupBox>


        <GroupBox Grid.Row="2" Header="Единицы" Style="{StaticResource GroupBoxStyle}">
            <StackPanel Orientation="Horizontal" Margin="3,5,0,5">
                <RadioButton GroupName="Unit" Content="Пиксели"
                             IsChecked="{Binding ScaleUnits,
                                Converter={StaticResource enumBool}, ConverterParameter=Pixel, Mode=TwoWay}" />
                <RadioButton GroupName="Unit" Content="DIP" Style="{StaticResource HorizontalToggleButtonStyle}"
                             IsChecked="{Binding ScaleUnits, 
                                Converter={StaticResource enumBool}, ConverterParameter=DIP, Mode=TwoWay}" />
                <RadioButton GroupName="Unit" Content="Пункты" Style="{StaticResource HorizontalToggleButtonStyle}"
                             IsChecked="{Binding ScaleUnits, 
                                Converter={StaticResource enumBool}, ConverterParameter=Point, Mode=TwoWay}" />
                <RadioButton GroupName="Unit" Content="Дюймы" Style="{StaticResource HorizontalToggleButtonStyle}"
                             IsChecked="{Binding ScaleUnits, 
                                Converter={StaticResource enumBool}, ConverterParameter=Inch, Mode=TwoWay}" />
                <RadioButton GroupName="Unit" Content="Сантиметры" Style="{StaticResource HorizontalToggleButtonStyle}"
                             IsChecked="{Binding ScaleUnits, 
                                Converter={StaticResource enumBool}, ConverterParameter=CM, Mode=TwoWay}" />
                <RadioButton GroupName="Unit" Content="Проценты" Style="{StaticResource HorizontalToggleButtonStyle}"
                             IsChecked="{Binding ScaleUnits, 
                                Converter={StaticResource enumBool}, ConverterParameter=Percent, Mode=TwoWay}" />
            </StackPanel>
        </GroupBox>


        <GroupBox Grid.Row="3" Header="Цветовая тема" Style="{StaticResource GroupBoxStyle}">
            <StackPanel Orientation="Horizontal" Margin="3,5,0,5">
                <RadioButton GroupName="Color" Content="Светлая"
                             IsChecked="{Binding ColorTheme, 
                                Converter={StaticResource enumBool}, ConverterParameter=Light, Mode=TwoWay}" />
                <RadioButton GroupName="Color" Content="Тёмная" Style="{StaticResource HorizontalToggleButtonStyle}"
                             IsChecked="{Binding ColorTheme, 
                                Converter={StaticResource enumBool}, ConverterParameter=Dark, Mode=TwoWay}" />
                <RadioButton GroupName="Color" Content="Пользовательская" Style="{StaticResource HorizontalToggleButtonStyle}"
                             IsChecked="{Binding ColorTheme, 
                                Converter={StaticResource enumBool}, ConverterParameter=Custom, Mode=TwoWay}" />
            </StackPanel>
        </GroupBox>


        <GroupBox Grid.Row="4" Header="Шрифты" Style="{StaticResource GroupBoxStyle}">
            <Grid Margin="3,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Семейство шрифтов"
                           Style="{StaticResource FontTextBlockStyle}" />
                <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Style="{StaticResource FontInputControlStyle}"
                          Width="200"
                          ItemsSource="{Binding Path=FontFamilies}"
                          SelectedValuePath="FamilyName"
                          SelectedValue="{Binding Path=FontFamily}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FamilyName}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMonospaced}" Value="True">
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Размер шрифта линейки"
                           Style="{StaticResource FontTextBlockStyle}" />
                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource FontTextBoxStyle}">
                    <TextBox.Text>
                        <Binding Path="FontSize" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" Delay="1250">
                            <Binding.ValidationRules>
                                <local:ValueRangeRule Min="8" Max="24" />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <!--<TextBlock Grid.Row="1" Grid.Column="2" Text="432.5"
                           Style="{StaticResource FontTextBlockSampleStyle}"
                           FontFamily="{Binding Path=FontFamily}"
                           FontSize="{Binding Path=FontSize}"/>-->

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Размер шрифта маркеров"
                           Style="{StaticResource FontTextBlockStyle}" />
                <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource FontTextBoxStyle}">
                    <TextBox.Text>
                        <Binding Path="MarkerFontSize" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" Delay="1250">
                            <Binding.ValidationRules>
                                <local:ValueRangeRule Min="8" Max="24" />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <!--<TextBlock Grid.Row="2" Grid.Column="2" Text="432.5"
                           Style="{StaticResource FontTextBlockSampleStyle}"
                           FontFamily="{Binding Path=FontFamily}"
                           FontSize="{Binding Path=MarkerFontSize}" />-->

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Размер шрифта настроек"
                           Style="{StaticResource FontTextBlockStyle}" />
                <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource FontTextBoxStyle}">
                    <TextBox.Text>
                        <Binding Path="DialogFontSize" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" Delay="1250">
                            <Binding.ValidationRules>
                                <local:ValueRangeRule Min="8" Max="24" />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <!--<TextBlock Grid.Row="3" Grid.Column="2" Text="432.5"
                           Style="{StaticResource FontTextBlockSampleStyle}"
                           FontFamily="{Binding Path=FontFamily}"
                           FontSize="{Binding Path=DialogFontSize}" />-->
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="5" Header="Лупа" Style="{StaticResource GroupBoxStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="Ширина" Margin="3,0,0,0" />
                    <local:IntegerTextBox Width="70" VerticalAlignment="Center" Margin="3,3,0,3" 
                                          Step="10" Minimum="100" Maximum="2000" 
                                          Value="{Binding MagnifierWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Высота" Margin="20,0,0,0" />
                    <local:IntegerTextBox Margin="3,3,0,3" Width="70" VerticalAlignment="Center"
                                          Step="10" Minimum="100" Maximum="2000" 
                                          Value="{Binding MagnifierHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <DockPanel LastChildFill="true" Margin="0,2,0,0">
                    <Label Content="Увеличение" Margin="3,0,0,5" />
                    <Slider VerticalAlignment="Center"
                            Value="{Binding Magnification}"
                            Minimum="1.0"
                            Maximum="4.0"
                            TickFrequency=".1"
                            IsSnapToTickEnabled="True" 
                            AutoToolTipPlacement="TopLeft"
                            AutoToolTipPrecision="1"
                            Margin="0,0,5,0" />
                </DockPanel>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="6" Header="Угол" Style="{StaticResource GroupBoxStyle}">
            <StackPanel Orientation="Horizontal">
                <CheckBox Content="Показывать перпендикуляр" Margin="3,5,0,0"
                          IsChecked="{Binding Perpendicular}" />
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="7" Header="Клавиатура" Style="{StaticResource GroupBoxStyle}">
            <StackPanel Margin="3,0,0,0">
                <TextBlock Text="Перемещение окна линейки: Клавиши со стрелками." />
                <TextBlock Text="Перемещение курсора мыши: Клавиша Ctrl + стрелки." />
                <TextBlock Text="Изменение длины линейки: Клавиша Alt + стрелки." />
                <TextBlock Text="Клавиша Shift к комбинации клавиш ускоряет действие." />
            </StackPanel>
        </GroupBox>

    </Grid>
</Window>
